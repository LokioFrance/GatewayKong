# ─────────────────────────────────────────────────────────────────────────────
# .env.example — Kong API Gateway (Lokio)
# Copiez ce fichier en .env et remplissez les valeurs
# ─────────────────────────────────────────────────────────────────────────────

# ── Ports Kong ────────────────────────────────────────────────────────────────
KONG_PROXY_PORT=8000
KONG_ADMIN_PORT=8900

# ── JWT Secret (doit correspondre au DJANGO_SECRET_KEY du service area) ───────
# Récupérez la valeur dans : area/.env → DJANGO_SECRET_KEY
AREA_JWT_SECRET=changeme-copy-from-area-DJANGO_SECRET_KEY

# ── Adresses des microservices ────────────────────────────────────────────────
AREA_UPSTREAM=http://host.docker.internal:8001
BOXIFY_UPSTREAM=http://host.docker.internal:8002
MARKO_UPSTREAM=http://host.docker.internal:8003

# ── Comptes de service (compte gateway sur chaque microservice) ───────────────
# Ces comptes sont créés automatiquement par le deploy.sh de chaque microservice
# si GATEWAY_SERVICE_PASSWORD est défini dans leur .env.
# Utilisez le même mot de passe que GATEWAY_SERVICE_PASSWORD dans chaque microservice.

AREA_SERVICE_USERNAME=gateway
AREA_SERVICE_PASSWORD=changeme-same-as-area-GATEWAY_SERVICE_PASSWORD

BOXIFY_SERVICE_USERNAME=gateway
BOXIFY_SERVICE_PASSWORD=changeme-same-as-boxify-GATEWAY_SERVICE_PASSWORD

MARKO_SERVICE_USERNAME=gateway
MARKO_SERVICE_PASSWORD=changeme-same-as-marko-GATEWAY_SERVICE_PASSWORD

# ── Intervalle de rafraîchissement des tokens (secondes) ─────────────────────
# Les tokens JWT expirent à JWT_ACCESS_TOKEN_LIFETIME_MINUTES (60 min par défaut)
# → refresh à 55 min pour garder une marge de sécurité
TOKEN_REFRESH_INTERVAL=3300
